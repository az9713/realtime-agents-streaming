{
  "name": "agent-streaming-allaboutai",
  "version": "1.0.0",
  "description": "AI agent that builds software in parallel tmux panes and optionally streams to Twitch",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:stream": "tsx src/index.ts --stream",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "keywords": [
    "ai",
    "agent",
    "streaming",
    "twitch",
    "claude"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.7",
    "tmi.js": "^1.8.5"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/tmi.js": "^1.8.6",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
